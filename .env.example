# Copie para `.env` na raiz e preencha.
# Chave em https://platform.openai.com/api-keys — projeto com billing.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VITE_AI_ASSISTANT_URL=/api/receipt

# --- Vercel (dashboard → Settings → Environment Variables) ---
# Mesmo valor em Production + Preview; rode novo deploy depois de salvar.
# OPENAI_API_KEY     → secreta (servidor). Nunca use prefixo VITE_ na chave OpenAI.
# OPENAI_MODEL       → opcional (default gpt-4o-mini).
# VITE_AI_ASSISTANT_URL=/api/receipt → obrigatória no BUILD do frontend.
# O app deriva automaticamente …/assistant/statement para IA de fatura de cartão.

# --- Firebase (Console → criar projeto → Web app → sdk config) ---
# Se os quatro obrigatórios estiverem preenchidos: login real + Google (ative o provedor em Authentication).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
