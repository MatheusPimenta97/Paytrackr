# Copie para `.env` na raiz e preencha.
# Chave em https://platform.openai.com/api-keys — projeto com billing.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VITE_AI_ASSISTANT_URL=/api/paytrackr/assistant/image

# --- Vercel (dashboard → Settings → Environment Variables) ---
# Mesmo valor em Production + Preview; rode novo deploy depois de salvar.
# OPENAI_API_KEY     → secreta (servidor). Nunca use prefixo VITE_ na chave OpenAI.
# OPENAI_MODEL       → opcional (default gpt-4o-mini).
# VITE_AI_ASSISTANT_URL=/api/paytrackr/assistant/image → obrigatória no BUILD do frontend.
# O app deriva automaticamente …/assistant/statement para IA de fatura de cartão.
