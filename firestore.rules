rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Finanças por usuário — espelha `src/sync/firestoreFinanceSync.ts` (coleção `userFinances`).
     * Publique no Firebase Console → Firestore → Regras, ou com `firebase deploy --only firestore:rules`.
     */
    match /userFinances/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
