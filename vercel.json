{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/paytrackr/assistant/image",
      "destination": "/api/receipt"
    },
    {
      "source": "/api/paytrackr/assistant/statement",
      "destination": "/api/statement"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
